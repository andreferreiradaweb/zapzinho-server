generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                           String    @id @default(uuid())
  email                        String    @unique
  passwordHash                 String
  name                         String?
  phoneNumber                  String?
  address                      String?
  isActive                     Boolean
  emailVerified                Boolean   @default(false)
  Role                         Role
  CustomerType                 CustomerType
  Plan                         UserPlan  @default(PADRAO)
  trialExpiresAt               DateTime?
  onboardingMessageSentAt      DateTime?
  wapiInstanceId               String?   @unique
  wapiToken                    String?
  prospectingInstanceId        String?
  prospectingToken             String?
  createdAt                    DateTime  @default(now())
  Products                     Product[]
  ProductCategories            ProductCategory[]
  Leads                        Lead[]
  MessageTemplates             MessageTemplate[]
  Broadcasts                   Broadcast[]
  Automations                  Automation[]
  MessageLogs                  MessageLog[]
  BroadcastBlocks              BroadcastBlock[]
  LeadSales                    LeadSale[]
  ContactLists                 ContactList[]
  ProspectingBroadcasts        ProspectingBroadcast[]
}

enum UserPlan {
  PADRAO
  EXPERT
  VIP
}

enum Role {
  ADMIN
  CLIENT
}

enum CustomerType {
  B2C
  B2B
}

model ProductCategory {
  id        String    @id @default(uuid())
  name      String
  userId    String
  createdAt DateTime  @default(now())
  User      User      @relation(fields: [userId], references: [id])
  Products    Product[]
  Leads       Lead[]
  Automations Automation[]
}

model Product {
  id          String           @id @default(uuid())
  createdAt   DateTime         @default(now())
  title       String
  description String?
  code        String?
  price       String?
  costPrice   String?
  condition   String?
  photos      String[]
  User        User             @relation(fields: [userId], references: [id])
  userId      String
  Category    ProductCategory? @relation(fields: [categoryId], references: [id])
  categoryId  String?
  Leads         Lead[]
  LeadItems     LeadItem[]
  LeadSaleItems LeadSaleItem[]
  OrderItems    OrderItem[]
  Automations Automation[]
}

model Lead {
  id              String          @id @default(uuid())
  nome            String
  telefone        String
  email           String?
  message         String?
  Product         Product?        @relation(fields: [productId], references: [id])
  productId       String?
  Category        ProductCategory? @relation(fields: [categoryId], references: [id])
  categoryId      String?
  User            User            @relation(fields: [userId], references: [id])
  userId          String
  Status          LeadStatus
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  lastBroadcastAt     DateTime?
  lastClientMessageAt DateTime?
  BroadcastLeads  BroadcastLead[]
  MessageLogs     MessageLog[]
  BroadcastBlocks BroadcastBlock[]
  LeadItems       LeadItem[]
  LeadSales       LeadSale[]
}

model LeadSale {
  id        String         @id @default(uuid())
  leadId    String
  userId    String
  createdAt DateTime       @default(now())
  Lead      Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  User      User           @relation(fields: [userId], references: [id])
  Items     LeadSaleItem[]
}

model LeadSaleItem {
  id        String   @id @default(uuid())
  saleId    String
  productId String
  quantity  Int      @default(1)
  price     Float    @default(0)
  Sale      LeadSale @relation(fields: [saleId], references: [id], onDelete: Cascade)
  Product   Product  @relation(fields: [productId], references: [id])
}

model LeadItem {
  id        String  @id @default(uuid())
  leadId    String
  productId String
  quantity  Int     @default(1)
  Lead      Lead    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  Product   Product @relation(fields: [productId], references: [id])
}

enum LeadStatus {
  NOVO_INTERESSE
  CONTATO_FEITO
  NEGOCIACAO
  VENDIDO
  NAO_INTERESSADO
}

// Message templates for reuse
model MessageTemplate {
  id         String      @id @default(uuid())
  userId     String
  name       String
  content    String
  category   String?
  imageUrl   String?
  videoUrl   String?
  createdAt  DateTime    @default(now())
  User       User        @relation(fields: [userId], references: [id])
  Broadcasts   Broadcast[]
  Automations  Automation[]
}

// Broadcast campaigns
model Broadcast {
  id             String          @id @default(uuid())
  userId         String
  templateId     String?
  name           String
  message        String
  imageUrls      String[]
  videoUrl       String?
  status         BroadcastStatus @default(DRAFT)
  scheduledAt    DateTime?
  startedAt      DateTime?
  finishedAt     DateTime?
  totalSent      Int             @default(0)
  totalFailed    Int             @default(0)
  createdAt      DateTime        @default(now())
  User           User            @relation(fields: [userId], references: [id])
  Template       MessageTemplate? @relation(fields: [templateId], references: [id])
  BroadcastLeads BroadcastLead[]
}

enum BroadcastStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  FAILED
}

// Junction: which leads are in a broadcast + delivery status
model BroadcastLead {
  id          String        @id @default(uuid())
  broadcastId String
  leadId      String
  status      MessageStatus @default(PENDING)
  sentAt      DateTime?
  errorMsg    String?
  Broadcast   Broadcast     @relation(fields: [broadcastId], references: [id])
  Lead        Lead          @relation(fields: [leadId], references: [id])
}

// Automated recurring broadcast rules
model Automation {
  id                 String           @id @default(uuid())
  userId             String
  name               String
  message            String
  imageUrls          String[]
  videoUrl           String?
  templateId         String?
  isActive           Boolean          @default(false)
  productId          String?
  categoryId         String?
  leadStatus         LeadStatus?
  lastMessageRange   String?
  lastBroadcastRange String?
  createdAt          DateTime         @default(now())
  User               User             @relation(fields: [userId], references: [id])
  Template           MessageTemplate? @relation(fields: [templateId], references: [id])
  Product            Product?         @relation(fields: [productId], references: [id])
  Category           ProductCategory? @relation(fields: [categoryId], references: [id])
}

// Leads blocked from receiving broadcast messages
model BroadcastBlock {
  id        String   @id @default(uuid())
  userId    String
  leadId    String
  createdAt DateTime @default(now())
  User      User     @relation(fields: [userId], references: [id])
  Lead      Lead     @relation(fields: [leadId], references: [id])

  @@unique([userId, leadId])
}

// Full log of every WhatsApp message dispatched by the system
model MessageLog {
  id        String        @id @default(uuid())
  userId    String
  leadId    String?
  phone     String
  message   String
  type      MessageType
  status    MessageStatus @default(PENDING)
  sentAt    DateTime?
  errorMsg  String?
  createdAt DateTime      @default(now())
  User      User          @relation(fields: [userId], references: [id])
  Lead      Lead?         @relation(fields: [leadId], references: [id])
}

enum MessageStatus {
  PENDING
  SENT
  FAILED
}

enum MessageType {
  ONBOARDING
  REACTIVATION
  TRIAL_EXPIRY
  NPS
  BROADCAST
  AUTOMATION
  MANUAL
}

// --- Prospecting (mass import + two-step messaging) ---

model ContactList {
  id                    String                 @id @default(uuid())
  userId                String
  name                  String
  createdAt             DateTime               @default(now())
  User                  User                   @relation(fields: [userId], references: [id])
  Contacts              ImportedContact[]
  ProspectingBroadcasts ProspectingBroadcast[]
}

model ImportedContact {
  id              String                @id @default(uuid())
  contactListId   String
  name            String
  phone           String
  email           String?
  website         String?
  address         String?
  category        String?
  status          ImportedContactStatus @default(PENDING)
  warmupSentAt    DateTime?
  repliedAt       DateTime?
  templateSentAt  DateTime?
  convertedLeadId String?
  errorMsg        String?
  createdAt       DateTime              @default(now())
  ContactList     ContactList           @relation(fields: [contactListId], references: [id], onDelete: Cascade)
}

enum ImportedContactStatus {
  PENDING
  WARMUP_SENT
  REPLIED
  TEMPLATE_SENT
  CONVERTED
  FAILED
}

model ProspectingBroadcast {
  id              String          @id @default(uuid())
  userId          String
  contactListId   String
  name            String
  warmupMessage   String
  templateMessage String
  status          BroadcastStatus @default(DRAFT)
  startedAt       DateTime?
  finishedAt      DateTime?
  totalSent       Int             @default(0)
  totalFailed     Int             @default(0)
  createdAt       DateTime        @default(now())
  User            User            @relation(fields: [userId], references: [id])
  ContactList     ContactList     @relation(fields: [contactListId], references: [id])
}

// --- E-commerce models (existing) ---

model Customer {
  id        String    @id @default(uuid())
  name      String
  email     String    @unique
  phone     String?
  document  String?
  createdAt DateTime  @default(now())
  Orders    Order[]
  Addresses Address[]
}

model Address {
  id         String   @id @default(uuid())
  customerId String
  street     String
  number     String
  city       String
  state      String
  zipCode    String
  complement String?
  Customer   Customer @relation(fields: [customerId], references: [id])
}

model Order {
  id         String      @id @default(uuid())
  customerId String
  status     OrderStatus
  total      Float
  createdAt  DateTime    @default(now())
  OrderItems OrderItem[]
  Payment    Payment?
  Customer   Customer    @relation(fields: [customerId], references: [id])
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  productId String
  price     Float
  quantity  Int
  Order     Order   @relation(fields: [orderId], references: [id])
  Product   Product @relation(fields: [productId], references: [id])
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELED
}

model Payment {
  id        String        @id @default(uuid())
  orderId   String        @unique
  method    PaymentMethod
  status    PaymentStatus
  amount    Float
  provider  String
  createdAt DateTime      @default(now())
  Order     Order         @relation(fields: [orderId], references: [id])
}

enum PaymentMethod {
  PIX
  CARTAO
  BOLETO
}

enum PaymentStatus {
  PENDENTE
  APROVADO
  RECUSADO
}
